# PostgreSQL (buat database lewat aaPanel / psql)
DATABASE_URL=postgres://dbuser:dbpassword@127.0.0.1:5432/sman1sooko_kelas

# Port internal API (hanya diakses Nginx, jangan dibuka publik)
PORT=3005

# Waktu pembukaan portal (ISO 8601, timezone WIB)
